---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { events } from '../../data/events';
import Nav from '../../components/ui/Nav.astro';
import '../../styles/global.css';

const statusColors: Record<string, string> = {
  'Планируем': 'var(--steel)',
  'Записаны': 'var(--gold)',
  'Участвовали': 'var(--text-muted)',
  'Результаты': 'var(--gold-dim)',
};

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' });
};
---

<BaseLayout title="Соревнования">
  <Nav currentPath="/events" />

  <!-- HERO -->
  <section class="events-hero">
    <div class="events-hero-bg"></div>
    <div class="events-hero-content">
      <span class="section-tag">Расписание</span>
      <h1>Календарь соревнований</h1>
      <p class="events-hero-sub">Выставки, курсинг, рейсинг — наш путь к вершине.</p>
    </div>
  </section>

  <!-- EVENTS LIST -->
  <section class="events-list-section">
    <div class="events-list">
{events.map(event => (
        <div class="event-item">
          <div class="event-date">
            <span class="event-day">{formatDate(event.date).split(' ')[0]}</span>
            <span class="event-month">{formatDate(event.date).split(' ')[1]}</span>
          </div>
          <div class="event-card">
            <div class="event-header">
              <span class="event-type" style={`color: ${statusColors[event.type]}`}>{event.type}</span>
              <span class="event-status" style={`color: ${statusColors[event.status]}`}>{event.status}</span>
            </div>
            <h3 class="event-title">{event.title}</h3>
            <p class="event-location">{event.location}</p>
            {event.url && (
              <a href={event.url} class="event-link" target="_blank" rel="noopener">Подробнее →</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
/* HERO */
.events-hero {
  position: relative;
  min-height: 50vh;
  display: flex;
  align-items: center;
  padding: 8rem 4rem 4rem;
}
.events-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 50% 70% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
}
.events-hero-content { position: relative; }
.section-tag {
  display: inline-block;
  font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.75rem;
}
.events-hero h1 {
  font-size: clamp(3rem, 6vw, 5rem);
  color: var(--text);
  margin-bottom: 1rem;
}
.events-hero-sub {
  font-size: 1.1rem; color: var(--text-muted);
  max-width: 500px;
}

/* EVENTS LIST */
.events-list-section {
  padding: 4rem 4rem;
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.events-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  border: 1px solid var(--border);
  max-width: 900px;
}
.event-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.event-item:last-child { border-bottom: none; }
.event-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  border-right: 1px solid var(--border);
  background: var(--surface);
}
.event-day {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.5rem;
  color: var(--gold);
  line-height: 1;
}
.event-month {
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 0.5rem;
}
.event-card {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.event-header {
  display: flex;
  gap: 1rem;
  align-items: center;
}
.event-type {
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.3rem 0.8rem;
  border: 1px solid currentColor;
}
.event-status {
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.event-title {
  font-size: 1.5rem;
  color: var(--text);
  margin: 0;
}
.event-location {
  font-size: 1rem;
  color: var(--text-muted);
}
.event-link {
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  color: var(--gold);
  text-decoration: none;
  align-self: flex-start;
  margin-top: 0.5rem;
}
.event-link:hover { text-decoration: underline; }

/* MOBILE */
@media (max-width: 768px) {
  .events-hero { padding: 6rem 1.5rem 3rem; min-height: 40vh; }
  .events-list-section { padding: 3rem 1.5rem; }
  .events-list { max-width: none; }
  .event-item {
    grid-template-columns: 80px 1fr;
  }
  .event-date { padding: 1.5rem; }
  .event-day { font-size: 1.8rem; }
  .event-month { font-size: 0.7rem; }
  .event-card { padding: 1.5rem; }
  .event-title { font-size: 1.2rem; }
}
</style>
