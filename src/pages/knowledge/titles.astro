---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/ui/Nav.astro';
import TitlesTree from '../../components/TitlesTree';
import '../../styles/global.css';
---

<BaseLayout title="Дерево титулов">
  <Nav currentPath="/knowledge/titles" />

  <!-- HERO -->
  <section class="titles-hero">
    <div class="titles-hero-bg"></div>
    <div class="titles-hero-content">
      <span class="section-tag">Достижения</span>
      <h1>Дерево титулов РКФ</h1>
      <p class="titles-hero-sub">Интерактивная схема титулов по курсингу, шоу и рейсингу.</p>
    </div>
  </section>

  <!-- TREE -->
  <section class="tree-section">
    <TitlesTree client:only="react" />
  </section>
</BaseLayout>

<style>
/* HERO */
.titles-hero {
  position: relative;
  min-height: 40vh;
  display: flex;
  align-items: center;
  padding: 8rem 4rem 4rem;
}
.titles-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 50% 70% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
}
.titles-hero-content { position: relative; }
.section-tag {
  display: inline-block;
  font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.75rem;
}
.titles-hero h1 {
  font-size: clamp(2.5rem, 5vw, 4rem);
  color: var(--text);
  margin-bottom: 1rem;
}
.titles-hero-sub {
  font-size: 1.1rem; color: var(--text-muted);
  max-width: 500px;
}

/* TREE */
.tree-section {
  padding: 4rem 4rem;
  background: var(--surface);
  border-top: 1px solid var(--border);
}

/* MOBILE */
@media (max-width: 768px) {
  .titles-hero { padding: 6rem 1.5rem 3rem; min-height: 35vh; }
  .tree-section { padding: 3rem 1.5rem; }
}
</style>
