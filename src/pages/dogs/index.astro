---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { dogs } from '../../data/dogs';
import Nav from '../../components/ui/Nav.astro';
import '../../styles/global.css';
---

<BaseLayout title="Наши собаки">
  <Nav currentPath="/dogs" />

  <!-- HERO -->
  <section class="dogs-hero">
    <div class="dogs-hero-bg"></div>
    <div class="dogs-hero-content">
      <span class="section-tag">Спортсменки</span>
      <h1>Наши собаки</h1>
      <p class="dogs-hero-sub">Три собаки. Две породы. Один путь — к вершине.</p>
    </div>
  </section>

  <!-- DOGS GRID -->
  <section class="dogs-list-section">
    <div class="dogs-list-grid">
{dogs.map(dog => (
        <a href={`/dogs/${dog.slug}`} class="dog-card-large">
          <div class="dog-card-large-img" style={dog.photos.length > 0 ? `background-image: url('${dog.photos[0]}')` : ''}>
            {dog.photos.length === 0 && (
              <div class="dog-card-placeholder">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
              </div>
            )}
          </div>
          <div class="dog-card-large-body">
            <div class="dog-card-tags">
              {dog.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <h2>{dog.nickname}</h2>
            <p class="dog-fullname">{dog.fullName}</p>
            <p class="dog-breed">{dog.breed} · р. {dog.born}</p>
            <p class="dog-bio">{dog.bio}</p>
            <span class="dog-link">Подробнее →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
/* HERO */
.dogs-hero {
  position: relative;
  min-height: 50vh;
  display: flex;
  align-items: center;
  padding: 8rem 4rem 4rem;
}
.dogs-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 50% 70% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
}
.dogs-hero-content { position: relative; }
.section-tag {
  display: inline-block;
  font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.75rem;
}
.dogs-hero h1 {
  font-size: clamp(3rem, 6vw, 5rem);
  color: var(--text);
  margin-bottom: 1rem;
}
.dogs-hero-sub {
  font-size: 1.1rem; color: var(--text-muted);
  max-width: 500px;
}

/* DOGS LIST */
.dogs-list-section {
  padding: 4rem 4rem;
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.dogs-list-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  border: 1px solid var(--border);
}
.dog-card-large {
  display: block; text-decoration: none; color: inherit;
  background: var(--bg);
  border-right: 1px solid var(--border);
  transition: border-color 0.3s;
  overflow: hidden;
}
.dog-card-large:last-child { border-right: none; }
.dog-card-large:hover { border-color: var(--gold); }
.dog-card-large:hover .dog-card-large-img { transform: scale(1.03); }
.dog-card-large-img {
  height: 400px; overflow: hidden;
  background: linear-gradient(135deg, #1a1a1a 0%, #222 100%);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.6s ease;
  background-size: cover;
  background-position: center;
}
.dog-card-placeholder { color: var(--border); }
.dog-card-large-body { padding: 2rem; }
.dog-card-tags { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
.tag {
  font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.2rem 0.6rem;
  border: 1px solid var(--gold-dim); color: var(--gold-dim);
}
.dog-card-large-body h2 { font-size: 2.5rem; margin-bottom: 0.5rem; }
.dog-fullname {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  font-style: italic;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}
.dog-breed { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem; }
.dog-bio {
  font-size: 1rem; color: var(--text-muted);
  line-height: 1.8;
  margin-bottom: 1.5rem;
}
.dog-link { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--gold); }

/* MOBILE */
@media (max-width: 768px) {
  .dogs-hero { padding: 6rem 1.5rem 3rem; min-height: 40vh; }
  .dogs-list-section { padding: 3rem 1.5rem; }
  .dogs-list-grid { grid-template-columns: 1fr; }
  .dog-card-large { border-right: none; border-bottom: 1px solid var(--border); }
  .dog-card-large:last-child { border-bottom: none; }
  .dog-card-large-img { height: 300px; }
  .dog-card-large-body h2 { font-size: 2rem; }
}
</style>
